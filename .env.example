# Copy this file to .env and fill in real values. .env is gitignored.
# Both keys are required by dd-research skill — it will fail fast on startup
# if either is missing.

# Parallel.ai API key — https://parallel.ai (SDK/CLI, not MCP)
PARALLEL_API_KEY=

# Etherscan V2 API key — https://etherscan.io/myapikey (V2 is chainid-aware)
ETHERSCAN_API_KEY=
